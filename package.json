        "@prisma/client": "^7.7.0",
        "@redis/client": "^5.12.1",
        "@scalar/express-api-reference": "^0.9.8",
        "@sentry/bun": "^10.49.0",
        "@types/jsonwebtoken": "^9.0.10",
        "bcrypt": "^6.0.0",
