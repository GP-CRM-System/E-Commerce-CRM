{
  "name": "e-commerce-crm",
  "version": "2.0.0",
  "description": "Backend Repo for the ECommerce CRM System",
  "author": {
    "email": "seifusama@gmail.com",
    "name": "Seif Sheikhelarab",
    "url": "https://www.linkedin.com/in/seifusama"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seifsheikhelarab/E-Commerce-CRM.git"
  },
  "keywords": [
    "ecommerce",
    "crm",
    "backend",
    "typescript",
    "bun"
  ],
  "license": "MIT",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "bun --watch run src/index.ts --preload ./src/instrument.ts",
    "start": "bun run src/index.ts --preload ./src/instrument.ts",
    "lint": "eslint",
    "format": "prettier --write ./src",
    "format-check": "prettier --check \"src/**/*.ts\"",
    "generate": "prisma generate",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "test": "bun test",
    "seed": "bun src/scripts/seed.script.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.13",
    "@types/cors": "^2.8.19",
    "@types/dotenv": "^8.2.3",
    "@types/express": "^5.0.6",
    "@types/express-rate-limit": "^6.0.2",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.59.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@aws-sdk/s3-request-presigner": "^3.1038.0",
    "@better-auth/prisma-adapter": "^1.6.9",
    "@faker-js/faker": "^10.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@redis/client": "^5.12.1",
    "@scalar/express-api-reference": "^0.9.11",
    "@sentry/bun": "^10.50.0",
    "@types/jsonwebtoken": "^9.0.10",
    "better-auth": "^1.6.9",
    "bullmq": "^5.76.2",
    "cors": "^2.8.6",
    "csv-parse": "^6.2.1",
