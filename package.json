{
    "name": "e-commerce-crm",
    "version": "2.0.0",
    "description": "Backend Repo for the ECommerce CRM System",
    "author": {
        "email": "seifusama@gmail.com",
        "name": "Seif Sheikhelarab",
        "url": "https://www.linkedin.com/in/seifusama"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/seifsheikhelarab/E-Commerce-CRM.git"
    },
    "keywords": [
        "ecommerce",
        "crm",
        "backend",
        "typescript",
        "bun"
    ],
    "license": "MIT",
    "module": "src/index.ts",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "bun --watch run src/index.ts --preload ./src/instrument.ts",
        "start": "bun run src/index.ts --preload ./src/instrument.ts",
        "lint": "eslint src --ext .ts",
        "format": "prettier --write ./src",
        "format-check": "prettier --check \"src/**/*.ts\"",
        "generate": "prisma generate",
        "typecheck": "tsc --noEmit",
        "build": "tsc",
        "test": "bun test",
        "seed": "bun src/scripts/seed.script.ts"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/bcrypt": "^6.0.0",
        "@types/bun": "^1.3.12",
