# Server Configuration
PORT = 6892
NODE_ENV = development
CORS_ORIGIN = http://localhost:5173
TZ = UTC

# PostgreSQL Database URL
DATABASE_URL = postgresql://postgres:password@localhost:5432/crm

# Better Auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET = your-better-auth-secret-min-32-chars
BETTER_AUTH_URL = http://localhost:6892

# SMTP (for email notifications)
SMTP_HOST = smtp.example.com
SMTP_PORT = 587
SMTP_SECURE = false
SMTP_USER = your-smtp-user
SMTP_PASS = your-smtp-password
SMTP_FROM = CRM <noreply@yourdomain.com>

# Hugging Face AI
HF_API_URL = https://mzidan1-brieflyai.hf.space/process
HF_API_TOKEN = your-hf-api-token

# Redis (for BullMQ background jobs)
REDIS_URL = redis://localhost:6379

# Google OAuth (optional)
APP_URL = http://localhost:6892
GOOGLE_CLIENT_ID = your-google-client-id
GOOGLE_CLIENT_SECRET = your-google-client-secret
GOOGLE_CALLBACK_URL = http://localhost:6892/api/auth/callback/google

# Backblaze Bucket Key
B2_KEY_ID = b2-key-12345678
B2_APPLICATION_KEY = b2-app-key
B2_REGION = us-east-067
B2_BUCKET_NAME = briefly

# Sentry DSN
SENTRY_DSN = https://www.google.com

# Shopify Integration
SHOPIFY_CLIENT_ID = client_id
