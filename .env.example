# Meta Integration (WhatsApp / Messenger / Instagram)
META_VERIFY_TOKEN = your-verify-token
META_APP_SECRET = your-meta-app-secret
ACCESS_TOKEN = your-meta-access-token
PHONE_NUMBER_ID = your-whatsapp-phone-number-id
