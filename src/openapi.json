{
    "openapi": "3.1.0",
    "info": {
        "title": "E-Commerce CRM API",
        "description": "High-performance, multi-tenant CRM backend for e-commerce businesses.\n\n Test User: admin@example.com \n\n Password : Admin123! \n\n## Features\n- Customer management with RFM scoring and lifecycle tracking\n- Order and product catalog management\n- CSV/XLSX import/export with field mapping\n- Shopify integration with webhook sync\n- Role-based access control (RBAC)\n- Background job processing with BullMQ\n\n## Authentication\nAll endpoints require Bearer token authentication. Get a token from `/api/auth/sign-in/email`.\n\n## Rate Limits\n- Auth endpoints: 10 requests/minute\n- API endpoints: 100 requests/minute\n- Bulk operations: 20 requests/minute",
        "version": "2.0.0",
        "contact": {
            "name": "API Support",
            "url": "https://github.com/seifsheikhelarab/E-Commerce-CRM"
        },
        "license": {
            "name": "MIT",
            "url": "https://opensource.org/licenses/MIT"
        }
    },
    "servers": [
        {
            "url": "/api",
            "description": "Current environment"
        },
        {
            "url": "https://dev.api.example.com/api",
            "description": "Development server"
        },
        {
            "url": "https://staging.api.example.com/api",
            "description": "Staging server"
        },
        {
            "url": "https://api.example.com/api",
            "description": "Production server"
        }
    ],
    "tags": [
        {
            "name": "Customers",
            "description": "Customer management, notes, events, and RFM analytics"
        },
        {
            "name": "Products",
            "description": "Product catalog management"
        },
        {
            "name": "Orders",
            "description": "Order management and fulfillment"
        },
        {
            "name": "Segments",
            "description": "Customer segmentation and grouping"
        },
        {
            "name": "Imports",
            "description": "CSV/XLSX import jobs"
        },
        {
            "name": "Exports",
            "description": "CSV/XLSX export jobs"
        },
        {
            "name": "Roles",
            "description": "Custom role and permission management"
        },
        {
            "name": "Integrations",
            "description": "Shopify store connections"
        },
        {
            "name": "Sync",
            "description": "Data synchronization operations"
        },
        {
            "name": "Webhooks",
            "description": "Webhook handling and logging"
        },
        {
            "name": "Cron",
            "description": "Manual triggers for RFM and lifecycle recalculations"
        },
        {
            "name": "Notifications",
            "description": "In-app notification management"
        },
        {
            "name": "Templates",
            "description": "Email template management"
        },
        {
            "name": "Campaigns",
            "description": "Email marketing campaigns"
        },
        {
            "name": "Messaging",
            "description": "WhatsApp/Facebook messaging and conversations"
        },
        {
            "name": "Payments",
            "description": "Payment processing and callbacks"
        },
        {
            "name": "Tickets",
            "description": "Support ticket management"
        },
        {
            "name": "Audit Logs",
            "description": "System audit and activity logging"
        },
        {
            "name": "Analytics",
            "description": "General organization analytics and performance metrics"
        },
        {
            "name": "Reports",
            "description": "Dashboard and analytics reports"
        },
        {
            "name": "Health",
            "description": "System health checks"
        },
        {
            "name": "Subscriptions",
            "description": "Subscription plan management and billing"
        },
        {
            "name": "Tracking",
            "description": "Campaign email open/click tracking"
        },
        {
            "name": "Unsubscribe",
            "description": "Email unsubscribe handling"
        }
    ],
    "paths": {
        "/analytics": {
            "get": {
                "operationId": "getGeneralAnalytics",
                "summary": "Get general organization analytics",
                "tags": ["Analytics"],
                "responses": {
                    "200": {
                        "description": "General analytics fetched",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/AnalyticsResponse"
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" }
                },
                "security": [{ "bearerAuth": [] }]
            }
        },
        "/payments/initialize/{orderId}": {
            "post": {
                "operationId": "initializePayment",
                "summary": "Initialize payment for an order",
                "tags": ["Payments"],
                "parameters": [
                    {
                        "name": "orderId",
                        "in": "path",
                        "required": true,
                        "schema": { "type": "string" },
                        "description": "Order ID"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Payment initialized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessResponse"
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" },
                    "404": { "$ref": "#/components/responses/NotFound" }
                },
                "security": [{ "bearerAuth": [] }]
            }
        },
        "/payments/fawry/callback": {
            "post": {
                "operationId": "handlePaymentCallback",
                "summary": "Handle payment callback from Fawry",
                "tags": ["Payments"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "merchantRefNum",
                                    "fawryRefNo",
                                    "orderStatus",
                                    "checksum"
                                ],
                                "properties": {
                                    "merchantRefNum": { "type": "string" },
                                    "fawryRefNo": { "type": "string" },
                                    "orderStatus": {
                                        "type": "string",
                                        "enum": ["PAID", "FAILED"]
                                    },
                                    "checksum": { "type": "string" }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Callback handled successfully",
                        "content": {
                            "text/plain": {
                                "schema": { "type": "string", "example": "OK" }
                            }
                        }
                    },
                    "400": {
                        "description": "Verification failed",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string",
                                    "example": "Verification Failed"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/subscriptions/plans": {
            "get": {
                "operationId": "listSubscriptionPlans",
                "summary": "List all subscription plans",
                "tags": ["Subscriptions"],
                "parameters": [
                    {
                        "name": "includeInactive",
                        "in": "query",
                        "schema": { "type": "boolean", "default": false },
                        "description": "Include inactive plans"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "List of subscription plans",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { "type": "string" },
                                        "data": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/SubscriptionPlan"
                                            }
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "path": { "type": "string" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/subscriptions/current": {
            "get": {
                "operationId": "getCurrentSubscription",
                "summary": "Get current organization subscription",
                "tags": ["Subscriptions"],
                "responses": {
                    "200": {
                        "description": "Current subscription details",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { "type": "string" },
                                        "data": {
                                            "$ref": "#/components/schemas/Subscription",
                                            "nullable": true
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "path": { "type": "string" }
                                    }
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" }
                },
                "security": [{ "bearerAuth": [] }]
            }
        },
        "/subscriptions": {
            "post": {
                "operationId": "subscribeToPlan",
                "summary": "Subscribe to a plan",
                "tags": ["Subscriptions"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["planId"],
                                "properties": {
                                    "planId": {
                                        "type": "string",
                                        "description": "Plan ID to subscribe to"
                                    },
                                    "billingCycle": {
                                        "type": "string",
                                        "enum": ["monthly", "yearly"],
                                        "default": "monthly"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Subscription activated or payment required",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { "type": "string" },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "paymentRequired": {
                                                    "type": "boolean"
                                                },
                                                "subscription": {
                                                    "$ref": "#/components/schemas/Subscription"
                                                }
                                            }
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "path": { "type": "string" }
                                    }
                                }
                            }
                        }
                    }
                },
                "security": [{ "bearerAuth": [] }]
            }
        },
        "/subscriptions/cancel": {
            "patch": {
                "operationId": "cancelSubscription",
                "summary": "Cancel current subscription",
                "tags": ["Subscriptions"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "immediately": {
                                        "type": "boolean",
                                        "default": false,
                                        "description": "Cancel immediately or at end of billing period"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Subscription canceled",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": { "type": "string" },
                                        "data": {
                                            "$ref": "#/components/schemas/Subscription"
                                        },
                                        "timestamp": {
                                            "type": "string",
                                            "format": "date-time"
                                        },
                                        "path": { "type": "string" }
                                    }
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" }
                },
                "security": [{ "bearerAuth": [] }]
            }
        },
        "/subscriptions/initialize": {
            "post": {
                "operationId": "initializeSubscriptionPayment",
                "summary": "Initialize subscription payment",
                "tags": ["Subscriptions"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": ["planId"],
                                "properties": {
                                    "planId": { "type": "string" },
                                    "billingCycle": {
                                        "type": "string",
                                        "enum": ["monthly", "yearly"],
                                        "default": "monthly"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Subscription activated (if no payment required)",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/SuccessResponse"
                                }
                            }
                        }
                    },
                    "402": {
                        "description": "Payment required",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "success": { "type": "boolean" },
                                        "message": { "type": "string" },
                                        "data": {
                                            "type": "object",
                                            "properties": {
                                                "subscription": {
                                                    "$ref": "#/components/schemas/Subscription"
                                                },
                                                "fawry": {
                                                    "type": "object",
                                                    "properties": {
                                                        "merchantCode": {
                                                            "type": "string"
                                                        },
                                                        "merchantRefNum": {
                                                            "type": "string"
                                                        },
                                                        "amount": {
                                                            "type": "number"
                                                        },
                                                        "signature": {
                                                            "type": "string"
                                                        },
                                                        "fawryUrl": {
                                                            "type": "string"
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": { "$ref": "#/components/responses/Unauthorized" },
                    "403": { "$ref": "#/components/responses/Forbidden" }
                },
                "security": [{ "bearerAuth": [] }]
            }
        },
        "/subscriptions/fawry/callback": {
            "post": {
                "operationId": "handleSubscriptionPaymentCallback",
                "summary": "Handle Fawry payment callback for subscriptions",
                "tags": ["Subscriptions"],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "required": [
                                    "merchantRefNum",
                                    "fawryRefNo",
                                    "orderStatus",
                                    "checksum"
                                ],
                                "properties": {
                                    "merchantRefNum": {
                                        "type": "string",
                                        "description": "Merchant reference number (organization ID)"
                                    },
                                    "fawryRefNo": {
                                        "type": "string",
                                        "description": "Fawry reference number"
                                    },
                                    "orderStatus": {
                                        "type": "string",
                                        "enum": ["PAID", "CANCELLED", "FAILED"],
                                        "description": "Payment status"
                                    },
                                    "checksum": {
                                        "type": "string",
                                        "description": "Checksum for verification"
                                    }
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Callback handled successfully",
                        "content": {
                            "text/plain": {
                                "schema": { "type": "string", "example": "OK" }
                            }
                        }
                    },
                    "400": {
                        "description": "Missing required fields",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string",
                                    "example": "Missing required fields"
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Invalid checksum",
                        "content": {
                            "text/plain": {
                                "schema": {
                                    "type": "string",
                                    "example": "Invalid checksum"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT",
                "description": "JWT token from Better Auth sign-in endpoint"
            }
        },
        "schemas": {
            "Error": {
                "type": "object",
                "required": ["message", "code"],
                "properties": {
                    "message": {
                        "type": "string",
                        "description": "Human-readable error message"
                    },
                    "code": {
                        "type": "string",
                        "description": "Error code for programmatic handling"
                    },
                    "details": {
                        "type": "object",
                        "description": "Field-specific validation errors",
                        "additionalProperties": { "type": "string" }
                    },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "path": {
                        "type": "string",
                        "description": "Request path that caused the error"
                    }
                }
            },
            "SuccessResponse": {
                "type": "object",
                "required": ["message", "data"],
                "properties": {
                    "message": { "type": "string" },
                    "data": { "type": "object" },
                    "timestamp": { "type": "string", "format": "date-time" },
                    "path": { "type": "string" }
                }
            },
            "SubscriptionPlan": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": {
                        "type": "string",
                        "description": "Internal plan name"
                    },
                    "displayName": { "type": "string" },
                    "price": { "type": "number" },
                    "billingCycle": {
                        "type": "string",
                        "enum": ["monthly", "yearly"]
                    },
                    "features": {
                        "type": "object",
                        "additionalProperties": true
                    },
                    "isActive": { "type": "boolean" }
                }
            },
            "Subscription": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "organizationId": { "type": "string" },
                    "planId": { "type": "string" },
                    "status": {
                        "type": "string",
                        "enum": ["active", "canceled", "past_due", "trialing"]
                    },
                    "billingCycle": {
                        "type": "string",
                        "enum": ["monthly", "yearly"]
                    },
                    "currentPeriodStart": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "currentPeriodEnd": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "cancelAtPeriodEnd": { "type": "boolean" },
                    "paymentReference": { "type": "string", "nullable": true },
                    "createdAt": { "type": "string", "format": "date-time" },
                    "updatedAt": { "type": "string", "format": "date-time" },
                    "plan": { "$ref": "#/components/schemas/SubscriptionPlan" }
                }
            },
            "FawryPayment": {
                "type": "object",
                "properties": {
                    "merchantCode": { "type": "string" },
                    "merchantRefNum": { "type": "string" },
                    "amount": { "type": "number" },
                    "signature": { "type": "string" },
                    "fawryUrl": { "type": "string", "format": "uri" }
                }
            },
            "AnalyticsResponse": {
                "type": "object",
                "properties": {
                    "success": { "type": "boolean" },
                    "data": {
                        "type": "object",
                        "properties": {
                            "summary": {
                                "$ref": "#/components/schemas/AnalyticsSummary"
                            },
                            "campaignPerformance": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/CampaignPerformance"
                                }
                            },
                            "ticketsByStatus": {
                                "$ref": "#/components/schemas/TicketStats"
                            },
                            "customersByLifecycle": {
                                "type": "object",
                                "additionalProperties": { "type": "integer" }
                            },
                            "topProducts": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/components/schemas/TopProduct"
                                }
                            },
                            "supportOverview": {
                                "type": "object",
                                "properties": {
                                    "totalTickets": { "type": "integer" },
                                    "openTickets": { "type": "integer" },
                                    "topEmployee": {
                                        "$ref": "#/components/schemas/TopEmployee"
                                    }
                                }
                            }
                        }
                    }
                }
            },
            "AnalyticsSummary": {
                "type": "object",
                "properties": {
                    "totalCustomers": { "type": "integer" },
                    "totalProducts": { "type": "integer" },
                    "totalOrders": { "type": "integer" },
                    "totalRevenue": { "type": "number" }
                }
            },
            "CampaignPerformance": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "sentCount": { "type": "integer" },
                    "openCount": { "type": "integer" },
                    "clickCount": { "type": "integer" },
                    "conversionCount": { "type": "integer" }
                }
            },
            "TopProduct": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "totalSales": { "type": "integer" },
                    "revenue": { "type": "number" }
                }
            },
            "TopEmployee": {
                "type": "object",
                "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "ticketsSolved": { "type": "integer" }
                }
            },
            "TicketStats": {
                "type": "object",
                "properties": {
                    "open": { "type": "integer" },
                    "pending": { "type": "integer" },
                    "closed": { "type": "integer" }
                }
            }
        },
        "responses": {
            "Unauthorized": {
                "description": "Authentication required",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/Error" }
                    }
                }
            },
            "Forbidden": {
                "description": "Insufficient permissions",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/Error" }
                    }
                }
            },
            "NotFound": {
                "description": "Resource not found",
                "content": {
                    "application/json": {
                        "schema": { "$ref": "#/components/schemas/Error" }
                    }
                }
            }
        }
    }
}
